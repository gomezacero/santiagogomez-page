---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
const t = useTranslations(getLangFromUrl(Astro.url));
---

<button
  id="theme-toggle"
  type="button"
  aria-label={t('theme.toggle')}
  title={t('theme.toggle')}
  class="grid size-9 place-items-center rounded-md border border-line text-muted transition-colors hover:border-accent hover:text-accent"
>
  <!-- luna (visible en dark) -->
  <svg class="size-4 dark-only" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8Z" />
  </svg>
  <!-- sol (visible en light) -->
  <svg class="size-4 light-only" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path stroke-linecap="round" d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
  </svg>
</button>

<style>
  .light-only { display: none; }
  :global(:root[data-theme='light']) .light-only { display: block; }
  :global(:root[data-theme='light']) .dark-only { display: none; }
</style>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'light' ? 'dark' : 'light';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
