---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cards = [
  { title: t('ai.c1.title'), body: t('ai.c1.body'), tag: 'claude-code · codex' },
  { title: t('ai.c2.title'), body: t('ai.c2.body'), tag: 'claude · gpt · gemini' },
  { title: t('ai.c3.title'), body: t('ai.c3.body'), tag: 'llama · whisper · ollama' },
  { title: t('ai.c4.title'), body: t('ai.c4.body'), tag: 'pipelines · agentes · rag' },
];

const termLines =
  lang === 'es'
    ? [
        { cmd: 'claude "migra el módulo de pagos y escribe sus tests"', out: '✓ 14 archivos · tests en verde · listo para revisión' },
        { cmd: 'gemini "analiza este dataset y propón el esquema"', out: '✓ esquema SQL + índices sugeridos' },
        { cmd: 'ollama run llama3 --local', out: '✓ inferencia local · 0 datos fuera de la máquina' },
      ]
    : [
        { cmd: 'claude "migrate the payments module and write its tests"', out: '✓ 14 files · tests green · ready for review' },
        { cmd: 'gemini "analyze this dataset and propose the schema"', out: '✓ SQL schema + suggested indexes' },
        { cmd: 'ollama run llama3 --local', out: '✓ local inference · 0 data leaves the machine' },
      ];
---

<section id="ia" class="border-y border-line bg-surface/40">
  <div class="mx-auto max-w-6xl scroll-mt-20 px-5 py-20 md:py-24">
    <p class="section-index">{t('ai.index')} /</p>
    <h2 class="mt-2 font-display text-4xl font-semibold tracking-tight text-ink">
      {t('ai.title')}
    </h2>
    <p class="mt-3 max-w-2xl text-muted">{t('ai.subtitle')}</p>

    <div class="mt-10 grid items-start gap-10 lg:grid-cols-[1fr_380px]">
      <div class="grid gap-5 sm:grid-cols-2">
        {
          cards.map((card) => (
            <article class="reveal rounded-lg border border-line bg-surface p-6 transition-colors hover:border-accent/60">
              <h3 class="font-display text-xl font-medium text-ink">{card.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{card.body}</p>
              <p class="mt-4 font-mono text-[0.65rem] uppercase tracking-widest text-accent">
                {card.tag}
              </p>
            </article>
          ))
        }
      </div>

      <div class="reveal browser-frame lg:sticky lg:top-24" aria-hidden="true">
        <div class="chrome">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="ml-2">~/workflow</span>
        </div>
        <div class="space-y-4 p-5 font-mono text-xs leading-relaxed">
          {
            termLines.map((line) => (
              <div>
                <p class="text-ink">
                  <span class="text-accent">~$</span> {line.cmd}
                </p>
                <p class="mt-1 text-accent-2">{line.out}</p>
              </div>
            ))
          }
          <p class="blink-cursor text-muted">
            <span class="text-accent">~$</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
