---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = (await getCollection('projects', ({ id }) => id.startsWith(`${lang}/`))).sort(
  (a, b) => a.data.order - b.data.order,
);

const casePath = (slug: string) =>
  localizePath(lang, `${lang === 'es' ? '/proyectos' : '/projects'}/${slug.replace(`${lang}/`, '')}`)
    .replace('/en/en', '/en');
---

<section id="proyectos" class="mx-auto max-w-6xl scroll-mt-20 px-5 py-20 md:py-28">
  <p class="section-index">{t('featured.index')} /</p>
  <h2 class="mt-2 font-display text-4xl font-semibold tracking-tight text-ink md:text-5xl">
    {t('featured.title')}
  </h2>
  <p class="mt-3 max-w-xl text-muted">{t('featured.subtitle')}</p>

  <div class="mt-14 flex flex-col gap-20 md:gap-28">
    {
      projects.map((project, i) => {
        const slug = project.id.replace(`${lang}/`, '');
        const href = lang === 'es' ? `/proyectos/${slug}` : `/en/projects/${slug}`;
        return (
          <article
            class:list={[
              'reveal grid items-center gap-8 md:grid-cols-2 md:gap-12',
            ]}
          >
            <a
              href={href}
              class:list={['tilt-wrap block', i % 2 === 1 && 'md:order-2']}
              aria-label={project.data.title}
            >
              <div class="tilt browser-frame">
                <div class="chrome">
                  <span class="dot" />
                  <span class="dot" />
                  <span class="dot" />
                  <span class="ml-2 truncate">
                    {project.data.links.live?.replace('https://', '') ?? `${slug}.app`}
                  </span>
                </div>
                <Image
                  src={project.data.cover}
                  alt={`${project.data.title} — interfaz`}
                  widths={[480, 800, 1200]}
                  sizes="(min-width: 768px) 50vw, 100vw"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  class="aspect-[16/10] w-full object-cover"
                />
              </div>
            </a>
            <div>
              <p class="font-mono text-sm text-accent">
                {String(i + 1).padStart(2, '0')} — {project.data.year}
              </p>
              <h3 class="mt-2 font-display text-3xl font-semibold text-ink md:text-4xl">
                {project.data.title}
              </h3>
              <p class="mt-3 text-muted">{project.data.tagline}</p>

              <dl class="mt-6 flex flex-wrap gap-x-10 gap-y-4">
                {project.data.highlights.map((h) => (
                  <div>
                    <dt class="sr-only">{h.label}</dt>
                    <dd class="font-mono text-2xl font-medium text-accent-2">{h.metric}</dd>
                    <dd class="text-xs uppercase tracking-wider text-muted">{h.label}</dd>
                  </div>
                ))}
              </dl>

              <ul class="mt-6 flex flex-wrap gap-2" aria-label={t('case.stack')}>
                {project.data.stack.slice(0, 6).map((tech) => (
                  <li class="rounded border border-line px-2 py-1 font-mono text-xs text-muted">
                    {tech}
                  </li>
                ))}
              </ul>

              {project.data.private && (
                <p class="mt-4 inline-block rounded border border-line bg-surface px-2 py-1 font-mono text-xs text-muted">
                  🔒 {t('featured.private')}
                </p>
              )}

              <div class="mt-6 flex flex-wrap items-center gap-5">
                <a href={href} class="link-editorial font-medium text-ink">
                  {t('featured.readCase')} →
                </a>
                {project.data.links.live && (
                  <a
                    href={project.data.links.live}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="link-editorial text-sm text-muted"
                  >
                    {t('featured.visit')} ↗
                  </a>
                )}
                {!project.data.private && project.data.links.repo && (
                  <a
                    href={project.data.links.repo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="link-editorial text-sm text-muted"
                  >
                    {t('featured.repo')} ↗
                  </a>
                )}
              </div>
            </div>
          </article>
        );
      })
    }
  </div>
</section>
