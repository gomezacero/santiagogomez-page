---
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative overflow-hidden">
  <div class="blueprint-grid pointer-events-none absolute inset-0" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-6xl px-5 pb-24 pt-20 md:pb-32 md:pt-28">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted md:text-sm">
      {t('hero.kicker')}
    </p>
    <h1
      class="mt-6 font-display font-semibold leading-[1.02] tracking-tight text-ink"
      style="font-size: clamp(2.4rem, 7.5vw, 6rem);"
    >
      {t('hero.title.1')}<br />
      <span class="text-accent">{t('hero.title.2')}</span>
    </h1>
    <p class="blink-cursor mt-8 font-mono text-sm text-muted md:text-base">
      {t('hero.meta')}
    </p>
    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href="#proyectos"
        class="rounded-md bg-accent px-6 py-3 font-medium text-bg transition-transform hover:-translate-y-0.5"
      >
        {t('hero.cta.projects')} →
      </a>
      <a
        href={`/cv/santiago-gomez-cv-${lang}.pdf`}
        download
        class="rounded-md border border-line px-6 py-3 font-medium text-ink transition-colors hover:border-accent hover:text-accent"
      >
        {t('hero.cta.cv')}
      </a>
    </div>
  </div>
</section>
