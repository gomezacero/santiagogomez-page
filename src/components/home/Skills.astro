---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { skillGroups } from '@/data/skills';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="skills" class="mx-auto max-w-6xl scroll-mt-20 px-5 py-20 md:py-28">
  <p class="section-index">{t('skills.index')} /</p>
  <h2 class="mt-2 font-display text-4xl font-semibold tracking-tight text-ink">
    {t('skills.title')}
  </h2>
  <p class="mt-3 max-w-xl text-muted">{t('skills.subtitle')}</p>

  <div class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-5">
    {
      skillGroups.map((group) => (
        <div class="reveal">
          <h3 class="border-b border-line pb-2 font-mono text-xs uppercase tracking-[0.18em] text-accent">
            {group.title[lang]}
          </h3>
          <ul class="mt-3 space-y-1.5">
            {group.items.map((item) => (
              <li class="text-sm text-muted">{item}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <div class="reveal mt-14 rounded-lg border border-line bg-surface p-6 md:p-8">
    <h3 class="font-display text-2xl font-medium text-ink">{t('skills.soft.title')}</h3>
    <p class="mt-3 max-w-3xl leading-relaxed text-muted">{t('skills.soft.body')}</p>
  </div>
</section>
