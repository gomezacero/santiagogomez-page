---
import Base from '@/layouts/Base.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Base title="404 — Santiago Gómez Acero">
  <main class="mx-auto grid min-h-[60vh] max-w-6xl place-items-center px-5 py-20">
    <div class="text-center">
      <p class="font-mono text-sm text-accent">404</p>
      <h1 class="mt-3 font-display text-5xl font-semibold text-ink">{t('notfound.title')}</h1>
      <p class="mt-4 text-muted">{t('notfound.body')}</p>
      <a
        href="/"
        class="mt-8 inline-block rounded-md bg-accent px-6 py-3 font-medium text-bg"
      >
        {t('notfound.back')}
      </a>
    </div>
  </main>
</Base>
