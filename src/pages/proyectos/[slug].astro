---
import { getCollection, render } from 'astro:content';
import CaseStudy from '@/layouts/CaseStudy.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects', ({ id }) => id.startsWith('es/'))).sort(
    (a, b) => a.data.order - b.data.order,
  );
  return projects.map((project, i) => {
    const nextProject = projects[(i + 1) % projects.length];
    return {
      params: { slug: project.id.replace('es/', '') },
      props: {
        project,
        next: nextProject
          ? { title: nextProject.data.title, href: `/proyectos/${nextProject.id.replace('es/', '')}` }
          : null,
      },
    };
  });
}

const { project, next } = Astro.props;
const { Content } = await render(project);
---

<CaseStudy project={project} next={next}>
  <Content />
</CaseStudy>
